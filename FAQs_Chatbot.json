{
  "name": "RAG Chatbot with Qdrant",
  "nodes": [
    {
      "parameters": {
        "options": {
          "systemMessage": "You are a helpful customer support assistant. Answer questions based on the provided FAQ knowledge base. If you cannot find the answer, politely explain that and offer to connect the user with a human agent."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 2,
      "position": [250, 300],
      "id": "agent-main",
      "name": "AI Support Agent"
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list"
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.2,
      "position": [50, 300],
      "id": "chat-model",
      "name": "Chat Model",
      "credentials": {
        "openAiApi": {
          "id": "OPENAI_API",
          "name": "OpenAI Credential"
        }
      }
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.embeddingsOpenAi",
      "typeVersion": 1.2,
      "position": [50, 500],
      "id": "embeddings",
      "name": "Embeddings",
      "credentials": {
        "openAiApi": {
          "id": "OPENAI_API",
          "name": "OpenAI Credential"
        }
      }
    },
    {
      "parameters": {
        "mode": "retrieve-as-tool",
        "toolDescription": "Search the FAQ knowledge base for answers. Input the user's question exactly as asked.",
        "qdrantCollection": {
          "__rl": true,
          "value": "faq-collection",
          "mode": "list"
        },
        "options": {
          "limit": 3,
          "scoreThreshold": 0.7
        }
      },
      "type": "@n8n/n8n-nodes-langchain.vectorStoreQdrant",
      "typeVersion": 1.3,
      "position": [250, 500],
      "id": "faq-tool",
      "name": "FAQ Search",
      "credentials": {
        "qdrantApi": {
          "id": "QDRANT_API",
          "name": "Qdrant Credential"
        }
      }
    },
    {
      "parameters": {},
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1.3,
      "position": [50, 400],
      "id": "memory",
      "name": "Conversation Memory"
    },
    {
      "parameters": {
        "public": true,
        "initialMessages": "Hello! I'm your customer support assistant. How can I help you today?",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chatTrigger",
      "typeVersion": 1.1,
      "position": [-150, 300],
      "id": "chat-trigger",
      "name": "Chat Trigger",
      "webhookId": "chatbot-webhook"
    }
  ],
  "connections": {
    "Chat Trigger": {
      "main": [[{ "node": "AI Support Agent", "type": "main", "index": 0 }]]
    },
    "Chat Model": {
      "ai_languageModel": [[{ "node": "AI Support Agent", "type": "ai_languageModel", "index": 0 }]]
    },
    "Embeddings": {
      "ai_embedding": [[{ "node": "FAQ Search", "type": "ai_embedding", "index": 0 }]]
    },
    "FAQ Search": {
      "ai_tool": [[{ "node": "AI Support Agent", "type": "ai_tool", "index": 0 }]]
    },
    "Conversation Memory": {
      "ai_memory": [[{ "node": "AI Support Agent", "type": "ai_memory", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "timezone": "UTC",
    "callerPolicy": "workflowsFromSameOwner"
  },
  "id": "rag-chatbot-workflow",
  "tags": [
    { "id": "chatbot", "name": "chatbot" },
    { "id": "rag", "name": "rag" },
    { "id": "qdrant", "name": "qdrant" }
  ]
}